# Which provider to use: anthropic | openai | ollama
PROVIDER=anthropic

# Fill in the key for whichever provider you chose above.
ANTHROPIC_API_KEY=sk-ant-...
# OPENAI_API_KEY=sk-...
# (ollama needs no key — just run Ollama locally)

# Optional — https://tavily.com (free tier). Without it, news uses mock data.
TAVILY_API_KEY=tvly-...
